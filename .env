# ─── Backend Environment Variables ─────────────────────────
# Use local MongoDB when running on your machine.
MONGODB_URI=mongodb://127.0.0.1:27017/successmakerz

# If you want to use MongoDB Atlas instead, replace MONGODB_URI with your Atlas connection string.
# MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/successmakerz

# Port (Render sets this automatically, keep 5000 for local)
PORT=5000

# Your frontend domain (update after buying domain)
# Local dev:
FRONTEND_URL=http://localhost:5174
# Production (uncomment and set your domain after deployment):
# FRONTEND_URL=https://successmakerz.com
