# Production Environment Variables
# Copy this file to .env and fill in your actual values

# MongoDB Atlas Connection String
# Get this from: https://cloud.mongodb.com
# Format: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/successmakerz
MONGODB_URI=mongodb://mongodb:27017/successmakerz

# Port for backend server
PORT=5000

# Frontend URL (for CORS) - Update this with your domain
FRONTEND_URL=http://localhost

# Node Environment
NODE_ENV=production